{
  "name": "digital-marketing-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "pnpm store prune && pnpm rm -rf .next",
    "build:start": "pnpm run build && pnpm start",
    "build": "next build --webpack",
    "start": "next start",
    "analyzer": "pnpm dlx cross-env ANALYZE=true pnpm build",
    "lint": "eslint",
    "lint:ts": "eslint \"./src/**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"./src/**/*.{ts,tsx}\" --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/material": "^7.3.6",
    "@mui/material-nextjs": "^7.3.6",
    "@mui/system": "^7.3.8",
    "@prisma/adapter-mariadb": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "dotenv": "^17.2.3",
    "hono": "4.11.7",
    "next": "^16.1.6",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@prisma/dev": "latest",
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-docs": "^10.2.7",
    "@storybook/addon-vitest": "^10.2.7",
    "@storybook/nextjs-vite": "^10.2.7",
    "@storybook/test": "^8.6.15",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.2.7",
    "msw": "^2.12.10",
    "msw-storybook-addon": "^2.0.6",
    "@next/bundle-analyzer": "^16.1.6",
    "prettier": "^3.7.4",
    "prisma": "^7.3.0",
    "storybook": "^10.2.7",
    "typescript": "^5",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "@storybook/test": {
      "storybook": "$storybook"
    },
    "hono": "4.11.7"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
